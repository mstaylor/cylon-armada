# gcylon-armada Dockerfile - GPU-accelerated cylon-armada with cuDF/RMM
# Based on cylon/docker/gcylon/Dockerfile pattern
# Targets: ECS EC2 (g4dn/g5) and Rivanna HPC (A100/V100)
FROM nvidia/cuda:12.8.0-devel-ubuntu22.04
LABEL maintainer="cylondata@googlegroups.com"

ARG DEBIAN_FRONTEND=noninteractive
ARG CYLON_BRANCH=cylon-context-support

ENV LANG=C.UTF-8 LC_ALL=C.UTF-8
ENV PATH=/opt/conda/bin:$PATH

ENV CYLON_HOME=/cylon
ENV CYLON_BUILD=/cylon/cpp/build_cylon
ENV GCYLON_BUILD=/cylon/cpp/build_gcylon
ENV CONDA_PREFIX=/opt/conda/envs/cylon_dev
ENV UCX_HOME=/ucx
ENV UCC_HOME=/ucc
ENV CYLON_PREFIX=/cylon/install
ENV CYLON_ARMADA_PREFIX=/cylon-armada/install

ARG EXPOSE_ENV=33000
ENV EXPOSE_ENV $EXPOSE_ENV

ADD https://google.com cache_bust

WORKDIR $CYLON_HOME

# ---------------------------------------------------------------------------
# System dependencies
# ---------------------------------------------------------------------------

RUN DEBIAN_FRONTEND=noninteractive apt-get update -y --fix-missing && \
    apt-get install -y wget bzip2 ca-certificates curl git build-essential && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# ---------------------------------------------------------------------------
# Miniconda (Python 3.10)
# ---------------------------------------------------------------------------

RUN wget --quiet https://repo.anaconda.com/miniconda/Miniconda3-py310_23.3.1-0-Linux-x86_64.sh -O ~/miniconda.sh && \
    /bin/bash ~/miniconda.sh -b -p /opt/conda && \
    rm ~/miniconda.sh && \
    ln -s /opt/conda/etc/profile.d/conda.sh /etc/profile.d/conda.sh && \
    echo ". /opt/conda/etc/profile.d/conda.sh" >> ~/.bashrc && \
    echo "conda activate cylon_dev" >> ~/.bashrc && \
    echo "export LD_LIBRARY_PATH=$CYLON_PREFIX/lib:$CYLON_ARMADA_PREFIX/lib" >> ~/.bashrc && \
    /opt/conda/bin/conda install -n base conda-libmamba-solver -y && \
    /opt/conda/bin/conda config --set solver libmamba

# ---------------------------------------------------------------------------
# Cylon source
# ---------------------------------------------------------------------------

RUN git clone https://github.com/mstaylor/cylon.git $CYLON_HOME
RUN cd $CYLON_HOME && git checkout -b ${CYLON_BRANCH} origin/${CYLON_BRANCH}

SHELL ["/bin/bash", "--login", "-c"]

RUN conda env create -f $CYLON_HOME/conda/environments/cylon_NoUCX.yml

RUN . /opt/conda/etc/profile.d/conda.sh && \
    conda activate cylon_dev && \
    conda install -c anaconda boto3 -y && \
    conda install -c conda-forge redis-py -y && \
    pip install cloudmesh-openstack awslambdaric

# ---------------------------------------------------------------------------
# cuDF / RMM from rapidsai (GPU dataframe support)
# ---------------------------------------------------------------------------

RUN . /opt/conda/etc/profile.d/conda.sh && \
    conda activate cylon_dev && \
    conda install -c rapidsai -c conda-forge -c nvidia \
        cudf=24.10 libcudf=24.10 rmm=24.10 librmm=24.10 \
        cuda-version=12.8 -y && \
    conda list | grep -E "cudf|rmm|cccl"

# Remove conda UCC/UCX libraries to avoid conflicts with custom builds
RUN rm -f /opt/conda/envs/cylon_dev/lib/libucc* /opt/conda/envs/cylon_dev/lib/libucx* \
         /opt/conda/envs/cylon_dev/lib/libucp* /opt/conda/envs/cylon_dev/lib/libucs* \
         /opt/conda/envs/cylon_dev/lib/libuct*

RUN . /opt/conda/etc/profile.d/conda.sh && \
    conda activate cylon_dev && \
    conda install -c rapidsai -c conda-forge -c nvidia numpy cython setuptools -y

# ---------------------------------------------------------------------------
# Build tools
# ---------------------------------------------------------------------------

RUN apt-get update && apt-get install autoconf libtool cmake libnuma-dev -y

# ---------------------------------------------------------------------------
# UCX + UCC (communication layer for multi-GPU)
# ---------------------------------------------------------------------------

RUN git clone --single-branch -b v1.19.1 https://github.com/openucx/ucx.git $UCX_HOME && \
    cd $UCX_HOME && \
    ./autogen.sh && \
    ./configure --prefix=$UCX_HOME/install && \
    make -j$(nproc) install

RUN git clone --single-branch -b v1.6.0 https://github.com/openucx/ucc.git $UCC_HOME && \
    cd $UCC_HOME && \
    ./autogen.sh && \
    ./configure --prefix=$UCC_HOME/install --with-ucx=$UCX_HOME/install && \
    make -j$(nproc) install

# ---------------------------------------------------------------------------
# Redis C++ libraries (hiredis + redis-plus-plus)
# ---------------------------------------------------------------------------

RUN git clone https://github.com/redis/hiredis.git /hiredis && \
    cd /hiredis && \
    make && \
    make PREFIX=/usr/local LIBRARY_PATH=lib install && \
    ldconfig && \
    git clone https://github.com/sewenew/redis-plus-plus.git /redis-plus-plus && \
    cd /redis-plus-plus && \
    mkdir build && cd build && \
    cmake -DREDIS_PLUS_PLUS_CXX_STANDARD=11 -DCMAKE_INSTALL_PREFIX=/usr/local .. && \
    make && make install

# ---------------------------------------------------------------------------
# Build Cylon C++ (CPU library with UCX, UCC, Redis)
# ---------------------------------------------------------------------------

RUN . /opt/conda/etc/profile.d/conda.sh && \
    conda activate cylon_dev && \
    cd $CYLON_HOME && \
    python build.py -cmake-flags="-DCYLON_UCX=1 -DUCX_INSTALL_PREFIX=$UCX_HOME/install -DCYLON_UCC=1 -DUCC_INSTALL_PREFIX=$UCC_HOME/install -DCYLON_USE_REDIS=1 -DCYLON_FMI=1 -DCYLON_SIMD=1" -ipath="$CYLON_PREFIX" --cpp --python

# ---------------------------------------------------------------------------
# Build gcylon (GPU library) + pygcylon (Python bindings)
# ---------------------------------------------------------------------------

RUN . /opt/conda/etc/profile.d/conda.sh && \
    conda activate cylon_dev && \
    export CYLON_LIB_DIR=${CYLON_PREFIX}/lib && \
    mkdir -p ${GCYLON_BUILD} && \
    cd ${GCYLON_BUILD} && \
    cmake ${CYLON_HOME}/cpp/src/gcylon \
        -DCYLON_VERSION=0.7.0 \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_PREFIX_PATH="${CONDA_PREFIX}" \
        -DCMAKE_LIBRARY_PATH="${CONDA_PREFIX}/lib" \
        -DCMAKE_INSTALL_PREFIX="${CONDA_PREFIX}" \
        -DGCYLON_BUILD_TESTS=ON && \
    make -j$(nproc) && \
    make install

ENV LD_LIBRARY_PATH="${GCYLON_BUILD}/lib:${CYLON_PREFIX}/lib:${CONDA_PREFIX}/lib:${UCX_HOME}/install/lib:${UCC_HOME}/install/lib:/usr/local/lib"
ENV GCYLON_LIB_DIR="${GCYLON_BUILD}/lib"
ENV CYLON_LIB_DIR="${CYLON_PREFIX}/lib"

RUN . /opt/conda/etc/profile.d/conda.sh && \
    conda activate cylon_dev && \
    cd ${CYLON_HOME}/python/pygcylon && \
    export CUDA_HOME=/usr/local/cuda && \
    export LIBRARY_PATH="${CYLON_PREFIX}/lib:${LIBRARY_PATH}" && \
    python setup.py build_ext --inplace && \
    pip install --no-build-isolation .

# ---------------------------------------------------------------------------
# cylon-armada dependencies
# ---------------------------------------------------------------------------

RUN . /opt/conda/etc/profile.d/conda.sh && \
    conda activate cylon_dev && \
    pip install langchain-aws langchain-core cython cloudmesh-common pandas \
        llama-index-core llama-index-embeddings-bedrock

# ---------------------------------------------------------------------------
# Copy cylon-armada source code
# ---------------------------------------------------------------------------

COPY target/shared/scripts/ /cylon-armada/scripts/
COPY target/aws/scripts/lambda/python/armada_init.py /cylon-armada/armada_init.py
COPY target/aws/scripts/lambda/python/armada_executor.py /cylon-armada/armada_executor.py
COPY target/aws/scripts/lambda/python/armada_aggregate.py /cylon-armada/armada_aggregate.py
COPY cpp/ /cylon-armada/cpp/
COPY python/ /cylon-armada/python/

# ---------------------------------------------------------------------------
# Build cylon-armada C++ library (with Redis, FMI, CUDA)
# ---------------------------------------------------------------------------

RUN . /opt/conda/etc/profile.d/conda.sh && \
    conda activate cylon_dev && \
    mkdir -p /cylon-armada/cpp/build && \
    cd /cylon-armada/cpp/build && \
    cmake -DCYLON_PREFIX=$CYLON_PREFIX \
          -DCYLON_USE_REDIS=1 \
          -DCYLON_FMI=1 \
          -DCMAKE_INSTALL_PREFIX=$CYLON_ARMADA_PREFIX \
          -DCMAKE_BUILD_TYPE=Release \
          .. && \
    cmake --build . --parallel $(nproc) && \
    cmake --install .

# ---------------------------------------------------------------------------
# Build cylon-armada Python context bindings
# ---------------------------------------------------------------------------

RUN . /opt/conda/etc/profile.d/conda.sh && \
    conda activate cylon_dev && \
    cd /cylon-armada/python && \
    CYLON_PREFIX=$CYLON_PREFIX \
    CYLON_ARMADA_PREFIX=$CYLON_ARMADA_PREFIX \
    CYLON_HOME=$CYLON_HOME \
    CYLON_REDIS=1 \
    CYLON_FMI=1 \
    python setup.py build_ext --inplace

# ---------------------------------------------------------------------------
# Build Cython SIMD extension (Path A2)
# ---------------------------------------------------------------------------

RUN . /opt/conda/etc/profile.d/conda.sh && \
    conda activate cylon_dev && \
    cd /cylon-armada/python/simd && \
    CYLON_PREFIX=$CYLON_PREFIX python setup.py build_ext --inplace && \
    cp *.so /cylon-armada/scripts/simd/ 2>/dev/null || true

# ---------------------------------------------------------------------------
# Environment and entry point
# ---------------------------------------------------------------------------

EXPOSE $EXPOSE_ENV

ENV PYTHONPATH="$CYLON_PREFIX/lib:/cylon-armada/scripts:/cylon-armada/python:$PYTHONPATH"
ENV LD_LIBRARY_PATH="${GCYLON_BUILD}/lib:${CYLON_PREFIX}/lib:${CYLON_ARMADA_PREFIX}/lib:${CONDA_PREFIX}/lib:${UCX_HOME}/install/lib:${UCC_HOME}/install/lib:/usr/local/lib:/usr/local/cuda/lib64"
ENV SHARED_SCRIPTS_PATH="/cylon-armada/scripts"
ENV NVIDIA_VISIBLE_DEVICES=all
ENV NVIDIA_DRIVER_CAPABILITIES=compute,utility

WORKDIR /cylon-armada

# ECS EC2 / Rivanna: direct Python invocation
# Lambda (if needed): ENTRYPOINT ["python", "-m", "awslambdaric"] + CMD ["armada_executor.handler"]
#
# Override CMD per function:
#   armada_init.handler      — embed tasks, build Map payloads
#   armada_executor.handler  — route single task (GPU SIMD)
#   armada_aggregate.handler — collect results
ENTRYPOINT [ "/cylon/target/aws/scripts/lambda/runCyloninLambda.sh" ]
CMD [ "python", "-m", "awslambdaric", "armada_executor.handler" ]