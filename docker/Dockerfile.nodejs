# =============================================================================
# Stage 1: Rust builder
# Builds both WASM packages and the cylon-node native FMI addon (napi-rs).
# =============================================================================
FROM rust:1.85-slim AS rust-builder

RUN apt-get update -y && \
    apt-get install -y curl git pkg-config libssl-dev clang nodejs npm && \
    clang --version && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

# zstd-sys cross-compiles C for wasm32 using clang — must be explicit
ENV CC_wasm32_unknown_unknown=clang

# Install wasm-pack (for WASM builds) and napi-rs CLI (for native addon build)
RUN curl https://rustwasm.github.io/wasm-pack/installer/init.sh -sSf | sh
RUN rustup target add wasm32-unknown-unknown
RUN npm install -g @napi-rs/cli

ADD https://google.com cache_bust

# Clone cylon (source for both WASM and native FMI addon)
ARG CYLON_BRANCH=cylon-context-support
RUN git clone --depth 1 --branch ${CYLON_BRANCH} \
    https://github.com/mstaylor/cylon.git /cylon

# ---------------------------------------------------------------------------
# Build cylon-wasm (SIMD similarity search, WASM target)
# ---------------------------------------------------------------------------
RUN cd /cylon/rust/cylon-wasm && \
    wasm-pack build --target nodejs --release

# ---------------------------------------------------------------------------
# Build cylon-armada-wasm (armada-specific WASM extensions)
# ---------------------------------------------------------------------------
COPY rust/cylon-armada/ /cylon-armada/
COPY rust/cylon-armada-wasm/ /cylon-armada-wasm/
RUN cd /cylon-armada-wasm && \
    wasm-pack build --target nodejs --release

# ---------------------------------------------------------------------------
# Build cylon-node native FMI addon (napi-rs, x86_64 Linux glibc)
# Default features: fmi + redis + s3 — all pure Rust, no external C libs.
# Produces: cylon-node.linux-x64-gnu.node (loaded by index.js at runtime)
# ---------------------------------------------------------------------------
RUN cd /cylon/rust/cylon-node && \
    npm install && \
    napi build --platform --release

# =============================================================================
# Stage 2: Runtime image
# =============================================================================
FROM node:18-slim

RUN apt-get update -y && \
    apt-get install -y ca-certificates python3 make g++ cmake autoconf automake libtool libcurl4-openssl-dev && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

# ---------------------------------------------------------------------------
# Copy built WASM packages from builder stage
# ---------------------------------------------------------------------------
COPY --from=rust-builder /cylon/rust/cylon-wasm/pkg/ /app/cylon-wasm/
COPY --from=rust-builder /cylon-armada-wasm/pkg/ /app/cylon-armada-wasm/

ENV CYLON_WASM_PATH=/app/cylon-wasm/cylon_wasm_bg.wasm
ENV CYLON_WASM_BINDINGS=/app/cylon-wasm/cylon_wasm.js
ENV CYLON_ARMADA_WASM_PATH=/app/cylon-armada-wasm/cylon_armada_wasm_bg.wasm
ENV CYLON_ARMADA_WASM_BINDINGS=/app/cylon-armada-wasm/cylon_armada_wasm.js

# ---------------------------------------------------------------------------
# Copy cylon-node native FMI addon
# index.js auto-selects cylon-node.linux-x64-gnu.node at runtime.
# ---------------------------------------------------------------------------
COPY --from=rust-builder /cylon/rust/cylon-node/cylon-node.linux-x64-gnu.node /app/cylon-node/
COPY --from=rust-builder /cylon/rust/cylon-node/index.js /app/cylon-node/
COPY --from=rust-builder /cylon/rust/cylon-node/index.d.ts /app/cylon-node/

ENV CYLON_NODE_PATH=/app/cylon-node

# ---------------------------------------------------------------------------
# Application dependencies
# ---------------------------------------------------------------------------

WORKDIR /app

COPY target/aws/scripts/lambda/node/package.json /app/package.json
RUN npm install --production && npm install aws-lambda-ric

# cylon_host provides WASM host imports for distributed operations.
COPY docker/node/cylon_host.js /app/node_modules/cylon_host/index.js

# ---------------------------------------------------------------------------
# ONNX model (optional — loaded from S3 at runtime via ONNX_MODEL_S3_URI)
# ---------------------------------------------------------------------------
RUN mkdir -p /app/models
COPY docker/models/ /app/models/
ENV ONNX_MODEL_PATH=/app/models/astromae.onnx

# ---------------------------------------------------------------------------
# Application code
# ---------------------------------------------------------------------------
COPY target/aws/scripts/lambda/node/ /app/

# ---------------------------------------------------------------------------
# Lambda handler entry point
# ---------------------------------------------------------------------------
ENTRYPOINT ["npx", "aws-lambda-ric"]
CMD ["lambda_entry.handler"]