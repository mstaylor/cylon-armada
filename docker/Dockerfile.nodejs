FROM node:18-slim

# ---------------------------------------------------------------------------
# System dependencies
# ---------------------------------------------------------------------------

RUN apt-get update -y && \
    apt-get install -y ca-certificates python3 make g++ && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# ---------------------------------------------------------------------------
# Copy WASM modules (pre-built)
#
# Before running docker build, copy the pre-built packages into the
# cylon-armada repo so everything is under one build context:
#
#   # Build WASM packages
#   cd /path/to/cylon/rust/cylon-wasm && wasm-pack build --target nodejs --release
#   cd /path/to/cylon-armada/rust/cylon-armada-wasm && wasm-pack build --target nodejs --release
#
#   # Copy cylon-wasm pkg into cylon-armada for docker build
#   cp -r /path/to/cylon/rust/cylon-wasm/pkg /path/to/cylon-armada/docker/wasm/cylon-wasm
#   cp -r /path/to/cylon-armada/rust/cylon-armada-wasm/pkg /path/to/cylon-armada/docker/wasm/cylon-armada-wasm
#
#   # Build
#   cd /path/to/cylon-armada && docker build -f docker/Dockerfile.nodejs -t cylon-armada-nodejs .
# ---------------------------------------------------------------------------

COPY docker/wasm/cylon-wasm/ /app/cylon-wasm/
COPY docker/wasm/cylon-armada-wasm/ /app/cylon-armada-wasm/

ENV CYLON_WASM_PATH=/app/cylon-wasm/cylon_wasm_bg.wasm
ENV CYLON_WASM_BINDINGS=/app/cylon-wasm/cylon_wasm.js
ENV CYLON_ARMADA_WASM_PATH=/app/cylon-armada-wasm/cylon_armada_wasm_bg.wasm
ENV CYLON_ARMADA_WASM_BINDINGS=/app/cylon-armada-wasm/cylon_armada_wasm.js

# ---------------------------------------------------------------------------
# Application dependencies
# ---------------------------------------------------------------------------

WORKDIR /app

COPY target/aws/scripts/lambda/node/package.json /app/package.json
RUN npm install --production

# ---------------------------------------------------------------------------
# ONNX model (optional — can also be loaded from S3 at runtime)
# ---------------------------------------------------------------------------

ARG ONNX_MODEL_DIR=
COPY ${ONNX_MODEL_DIR:-/dev/null} /app/models/
ENV ONNX_MODEL_PATH=/app/models/astromae.onnx

# ---------------------------------------------------------------------------
# Copy application code
# ---------------------------------------------------------------------------

COPY target/aws/scripts/lambda/node/ /app/

# ---------------------------------------------------------------------------
# Lambda handler entry point
# ---------------------------------------------------------------------------

CMD ["context_handler.handler"]