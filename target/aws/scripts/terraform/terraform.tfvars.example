# Copy this to terraform.tfvars and fill in your values

aws_region = "us-east-1"
account_id = "123456789012"

# ECR image URIs (after docker push)
python_image_uri = "123456789012.dkr.ecr.us-east-1.amazonaws.com/cylon-armada-python:latest"
nodejs_image_uri = "123456789012.dkr.ecr.us-east-1.amazonaws.com/cylon-armada-nodejs:latest"

# Lambda configuration
python_memory_mb = 1024
nodejs_memory_mb = 512
lambda_timeout   = 300

# Redis — use existing or create new
# Option 1: Use existing Redis
redis_host         = "your-redis-host.cache.amazonaws.com"
create_elasticache = false

# Option 2: Create new ElastiCache (requires VPC)
# create_elasticache    = true
# elasticache_node_type = "cache.t3.micro"
# vpc_id                = "vpc-xxxxxxxx"
# subnet_ids            = ["subnet-xxxxxxxx", "subnet-yyyyyyyy"]
# security_group_ids    = ["sg-xxxxxxxx"]

# Bedrock defaults
bedrock_llm_model_id         = "anthropic.claude-3-haiku-20240307-v1:0"
bedrock_embedding_model_id   = "amazon.titan-embed-text-v2:0"
bedrock_embedding_dimensions = 1024
similarity_threshold         = 0.85
context_backend              = "cylon"

# Step Functions
step_functions_max_concurrency = 10