# Copy this to terraform.tfvars and fill in your values

aws_region          = "us-east-1"
account_id          = "448324707516"
ecr_repository_name = "cylon-armada"

# ECR image tags — Terraform constructs the full URI as:
#   <ecr_repository_url>:<tag>
python_image_tag = "cylon-armada-python"
nodejs_image_tag = "cylon-armada-nodejs"

# Lambda configuration
python_memory_mb = 1024
nodejs_memory_mb = 512
lambda_timeout   = 300

# S3
scripts_bucket_name = "staylor.dev2"
results_bucket_name = "staylor.dev2"

# S3 script hot-reload — all Lambdas pull handler + shared scripts from S3
# at cold-start via lambda_entry.py. Deploy bug fixes without image rebuilds:
#   aws s3 sync target/shared/scripts/ s3://staylor.dev2/cylon-armada/scripts/
#   aws s3 sync target/aws/scripts/lambda/python/ s3://staylor.dev2/cylon-armada/scripts/lambda/
# Can also be overridden per-invocation via event payload fields.
s3_scripts_prefix = "cylon-armada/scripts/"

# VPC — required for ECS Redis service and (optionally) Lambda VPC config
# Default VPC subnets (us-east-1a/1c) — survive terraform destroy
vpc_id              = "vpc-0f0b356963256cc2c"
ecs_task_subnet_ids = ["subnet-07995eea6c462cd73", "subnet-0979c94513025746c"]

# Lambda VPC config (optional — only needed if Lambda must reach VPC resources directly)
# subnet_ids         = ["subnet-xxxxxxxx", "subnet-yyyyyyyy"]
# security_group_ids = ["sg-xxxxxxxx"]

# Redis — Option 1: existing host (ElastiCache or external)
# redis_host         = "your-redis-host.cache.amazonaws.com"
# create_elasticache = false

# Redis — Option 2: ElastiCache (creates cluster + subnet group)
# create_elasticache    = true
# elasticache_node_type = "cache.t3.micro"
# subnet_ids            = ["subnet-xxxxxxxx", "subnet-yyyyyyyy"]
# security_group_ids    = ["sg-xxxxxxxx"]

# Redis — Option 3: ECS Fargate service from public ECR image
# Requires vpc_id and ecs_task_subnet_ids (public subnets).
# The task gets a public IP; Route 53 is updated automatically on each restart.
create_ecs_redis = true
redis_image_uri  = "public.ecr.aws/docker/library/redis:7.0"
redis_cpu        = 256
redis_memory_mb  = 512

# Route 53 DNS auto-update for ECS Redis
# The DNS updater Lambda fires on every task restart and upserts the A record.
# Required when create_ecs_redis = true.
route53_zone_id = "Z07564222HQKHFHJ8PNJ8"              # aws-cylondata.com hosted zone
redis_hostname  = "dev-cylon-redis1.aws-cylondata.com"  # FQDN for the ECS Redis task
redis_dns_ttl   = 30                                    # low TTL so clients re-resolve quickly after replacement

# Bedrock defaults
bedrock_llm_model_id         = "amazon.nova-lite-v1:0"
bedrock_embedding_model_id   = "amazon.titan-embed-text-v2:0"
bedrock_embedding_dimensions = 1024
similarity_threshold         = 0.85
context_backend              = "cylon"

# Step Functions
step_functions_max_concurrency = 10

# Rendezvous server (FMI direct channel)
rendezvous_host = "cylon-rendezvous.aws-cylondata.com"
rendezvous_port = 10000